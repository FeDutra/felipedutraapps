    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
