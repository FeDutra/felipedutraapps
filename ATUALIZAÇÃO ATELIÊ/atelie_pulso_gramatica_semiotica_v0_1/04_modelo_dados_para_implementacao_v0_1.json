{
  "version": "0.1",
  "project": "Ateliê PULSO",
  "coreRule": {
    "elementPlusTarget": "modulation",
    "elementPlusElement": "temporaryCompound",
    "compoundPlusTarget": "hybridAction"
  },
  "proximityWeights": {
