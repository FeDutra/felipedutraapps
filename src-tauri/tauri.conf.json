{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PULSO",
  "version": "0.1.0",
  "identifier": "com.felipedutraapps.pulso",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001/pulso/live?pulso_tauri_dev=1",
    "beforeDevCommand": "echo Next externo em 3001",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PULSO | Lótus Live",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/kokoro_runner"],
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
