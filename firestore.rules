rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regra básica de MVP: Exige autenticação para qualquer leitura ou escrita.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regras específicas para o workspace do PULSO (flexível para novos nomes de coleção)
    match /workspaces/{workspaceId}/{collectionName}/{documentId} {
      allow read, write: if request.auth != null;
    }
  }
}
