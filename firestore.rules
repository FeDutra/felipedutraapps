rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated access to the personal workspace and all its subcollections
    // Excludes everything else by default.
    match /workspaces/{workspaceId}/{document=**} {
      allow read, write: if request.auth != null && workspaceId == "felipe_dutra";
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
