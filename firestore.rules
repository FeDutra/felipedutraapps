rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Workspace pessoal: acesso somente para usuário autenticado com Google
    match /workspaces/{workspaceId}/{document=**} {
      allow read, write: if request.auth != null && workspaceId == "felipe_dutra";
    }

    // Qualquer outro path: bloqueado por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
